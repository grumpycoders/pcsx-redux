    "version": "0.2.0",
    "configurations": [
        {
            "name": "(cppdbg) Launch OpenBIOS",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/src/mips/openbios/openbios.elf",
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "targetArchitecture": "mips",
            "miDebuggerPath": "gdb-multiarch",
            "miDebuggerServerAddress": "localhost:3333",
            "stopAtConnect": true,
            "windows": {
                "miDebuggerPath": "gdb-multiarch.exe"
            },
            "setupCommands": [
                {
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "text": "cd ${workspaceFolder}"
                },
                {
                    "text": "set substitute-path /project ."
                }
            ],
            "postRemoteConnectCommands": [
                {
                    "text": "monitor reset halt"
                },
                {
                    "text": "load ./src/mips/openbios/openbios.elf"
                }
            ],
            "launchCompleteCommand": "None",
            "visualizerFile": "${workspaceFolder}/src/mips/psyqo/psyqo.natvis",
            "showDisplayString": true
        },

